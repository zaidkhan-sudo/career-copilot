# ============================================
# CareerPilot — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# -----------------------------------------
# Firebase Client Configuration
# -----------------------------------------
# Get these from your Firebase Console:
# https://console.firebase.google.com/ > Project Settings > General > Your Apps > Web App
#
# 1. Go to Firebase Console
# 2. Create a new project (or select existing)
# 3. Click "Add App" > Web
# 4. Copy the config values below

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# -----------------------------------------
# Firebase Admin (Server-side)
# -----------------------------------------
# Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the ENTIRE JSON content as a single-line string:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

FIREBASE_SERVICE_ACCOUNT_KEY=

# -----------------------------------------
# Google OAuth Setup (via Firebase)
# -----------------------------------------
# 1. Go to Firebase Console > Authentication > Sign-in method
# 2. Enable "Google" provider
# 3. Add your project's authorized domain
#
# For development, localhost is automatically allowed.

# -----------------------------------------
# GitHub OAuth Setup (via Firebase)
# -----------------------------------------
# 1. Go to GitHub Developer Settings: https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Set Homepage URL: http://localhost:3000
# 4. Set Authorization callback URL:
#    https://your-project.firebaseapp.com/__/auth/handler
# 5. Copy Client ID and Client Secret
# 6. Go to Firebase Console > Authentication > Sign-in method > GitHub
# 7. Enable GitHub provider, paste Client ID & Secret

# -----------------------------------------
# Site Configuration
# -----------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------
# Future: Additional Services (for production)
# -----------------------------------------

# Pinecone (Vector DB for semantic search)
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=
# PINECONE_INDEX=

# Groq (LLM API) / Google Gemini
# GROQ_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Resend (Email)
# RESEND_API_KEY=

# Upstash Redis (Caching & Queues)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
